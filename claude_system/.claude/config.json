{
  "model": "claude-sonnet-4-20250514",
  "maxTokens": 8192,
  "temperature": 0.3,
  "defaults": {
    "language": "vi",
    "codeStyle": "clean",
    "errorHandling": "explicit",
    "testFramework": "jest"
  },
  "memory": {
    "enabled": true,
    "autoSave": true,
    "maxContextWindow": 200000
  },
  "agents": {
    "enabled": true,
    "maxConcurrent": 3,
    "defaultTimeout": 30000
  },
  "hooks": {
    "preGeneration": true,
    "postGeneration": true,
    "validation": true
  },
  "logging": {
    "level": "info",
    "structured": true,
    "destination": "stdout"
  }
}
